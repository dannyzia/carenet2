# Copy to `.env` and fill in values. Never commit `.env`.

# Care seeker (guardian/patient) direct discovery & messaging with caregivers.
# Default in code is false when unset. Set to true only when enabling search/compare/profile/DM between those roles.
# VITE_CARE_SEEKER_CAREGIVER_CONTACT_ENABLED=true

# Playwright sets VITE_PLAYWRIGHT_E2E=true when it starts Vite (see playwright.config.ts).
# You normally do not set this manually.

# Main Supabase project (auth, app data)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key

# Optional: separate Supabase project for medicine search API
VITE_MEDICINE_API_URL=https://YOUR_MEDICINE_PROJECT.supabase.co
VITE_MEDICINE_API_KEY=your_medicine_project_publishable_or_anon_key

# Optional: backend API base (defaults to "/api" if unset)
# VITE_API_URL=/api

# Booking / package subscription (optional — set for pricing hints, payment logos, and DB fallbacks)
# VITE_BOOKING_PLATFORM_FEE_RATE=0.05
# VITE_BOOKING_MIN_PRICE_HINT_BDT=400
# VITE_PAYMENT_BKASH_LOGO_URL=https://upload.wikimedia.org/wikipedia/commons/5/5c/Bkash_logo.png
# VITE_SUBSCRIPTION_DEFAULT_PARTY_NAME=
# VITE_SUBSCRIPTION_DEFAULT_PARTY_PHONE=

# Optional: Tolgee self-hosted (Docker). The app does NOT wrap TolgeeProvider by default —
# if the API is down or CORS blocks the browser, tolgee.run() can hang and block the UI.
# When enabled in code, allow your Vite dev origin on the Tolgee server.
# VITE_APP_TOLGEE_API_URL=http://localhost:8080
# VITE_APP_TOLGEE_API_KEY=your_tolgee_api_key
