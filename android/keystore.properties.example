# Copy this file to keystore.properties (same folder) and fill in values.
# keystore.properties and *.jks are gitignored — never commit them.
#
# Create an upload keystore once (example):
#   keytool -genkeypair -v -keystore carenet-upload-key.jks -keyalg RSA -keysize 2048 -validity 10000 -alias carenet
# Store the keystore file in this android/ directory (or use an absolute storeFile path).

storeFile=carenet-upload-key.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=carenet
keyPassword=YOUR_KEY_PASSWORD
