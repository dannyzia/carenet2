# =============================================================================
# DEPENDENCIES
# =============================================================================
node_modules/
.pnp
.pnp.js

# =============================================================================
# BUILD OUTPUT
# =============================================================================
dist/
dist-ssr/
build/

# =============================================================================
# ENVIRONMENT & SECRETS
# =============================================================================
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
!.env.example
# Firebase service account private keys (never commit)
*firebase-adminsdk*.json
# Stray Local by Flywheel / WordPress tree at repo root only (do not commit)
/app/

# =============================================================================
# VITE / TYPESCRIPT
# =============================================================================
*.tsbuildinfo
.vite/
vite.config.ts.timestamp-*

# =============================================================================
# SUPABASE
# =============================================================================
.supabase/
supabase/.temp/
supabase/config.toml.local

# =============================================================================
# CAPACITOR / NATIVE
# =============================================================================
# Commit android/ / ios/ for team builds; ignore machine-local and Gradle outputs.
android/.gradle/
android/**/build/
# Fallback :app Gradle output when not using LOCALAPPDATA (see android/app/build.gradle)
.carenet-android-build/
android/local.properties
android/.idea/
android/*.iml
android/app/release/
# Firebase config is optional until FCM is wired (use .example in repo)
android/app/google-services.json
# Play signing (never commit)
android/keystore.properties
android/*.jks
android/*.keystore
ios/App/Pods/
ios/**/build/
ios/App/App/public/

# =============================================================================
# TESTING
# =============================================================================
coverage/
playwright-report/
test-results/
.playwright/
blob-report/

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

