{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:cap": "node scripts/capacitor-web-build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:phase0": "playwright test e2e/carenet/",
    "translate": "node scripts/translate.mjs",
    "translate:sidebar": "node scripts/translate.mjs --fill-identical --key-prefix=sidebar. --key-prefix=roles.",
    "translate:list": "node scripts/translate.mjs --list",
    "translate:preview": "node scripts/translate.mjs --dry",
    "translate:verify": "node scripts/translate.mjs --verify",
    "translate:check": "node scripts/check-translations.mjs",
    "translate:check-strict": "node scripts/check-translations.mjs --strict",
    "i18n:sync": "node scripts/sync-i18n-keys.mjs",
    "i18n:sync:dry": "node scripts/sync-i18n-keys.mjs --dry",
    "i18n:extract": "i18next --config i18next-parser.config.mjs --silent",
    "i18n:extract:verbose": "i18next --config i18next-parser.config.mjs",
    "i18n:extract:ci": "i18next --config i18next-parser.config.mjs --silent --fail-on-update",
    "i18n:refresh": "npm run i18n:extract && npm run i18n:sync",
    "dev": "vite",
    "ai:sync": "node scripts/sync-ai-context.mjs",
    "cap:sync": "npm run build:cap && npx cap sync android",
    "cap:copy": "npx cap copy android",
    "cap:open": "npx cap open android",
    "cap:run:android": "npm run build:cap && npx cap run android",
    "android:release": "node scripts/android-release.mjs",
    "android:release:apk": "node scripts/android-release.mjs apk",
    "android:release:debug-sign": "node scripts/android-release.mjs -- -PcarenetAllowDebugSigning=true"
